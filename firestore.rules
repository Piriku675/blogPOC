// ─── firestore.rules ──────────────────────────────────────────────────────────
// Firestore Security Rules — Blog Article POC
//
// Phase 1 scope: no authentication, no user roles.
// Articles are publicly readable. All writes are locked down to server-side
// (admin SDK / seed script) only — no client-side writes are permitted.
//
// To deploy:
//   firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Articles ────────────────────────────────────────────────────────────
    // Public read access so the article page can fetch content without auth.
    // Writes are denied to all clients; only the Admin SDK (used in seed.js
    // and any future server-side CMS) can write.

    match /articles/{articleId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Everything else ─────────────────────────────────────────────────────
    // Deny all access to any other collection by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
